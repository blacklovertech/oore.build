{
  "name": "oore-build",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:docs": "cd apps/docs-site && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "build:docs": "cd apps/docs-site && bun run build",
    "docs:check": "bash scripts/check-feature-docs.sh",
    "ui:init": "bash scripts/apply-shadcn-preset.sh"
  }
}
